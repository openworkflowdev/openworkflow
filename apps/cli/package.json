{
  "name": "@openworkflow/cli",
  "version": "0.4.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "bin": {
    "openworkflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!*.test.*",
    "!*.testsuite.*",
    "!*.tsbuildinfo"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "nypm": "^0.6.8"
  },
  "devDependencies": {
    "openworkflow": "*",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "openworkflow": "^0.6.0 || ^0.7.0 || ^0.8.0 || ^0.9.0"
  }
}
